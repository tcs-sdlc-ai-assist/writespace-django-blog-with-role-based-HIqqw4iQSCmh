# .env.example
# Environment variable template for writespace-blog
# Copy this file to .env and fill in the values for local development.
# For Vercel deployment, set these variables in the Vercel project settings.

# Django secret key — generate one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# REQUIRED in production. Never commit the actual secret key.
SECRET_KEY=your-secret-key-here

# Debug mode — set to True for local development, MUST be False in production.
# Defaults to False if not set.
DEBUG=True

# Database URL — PostgreSQL connection string.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
# For local development with default PostgreSQL:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/writespace

# Comma-separated list of allowed hostnames.
# For local development, localhost and 127.0.0.1 are typical.
# For Vercel, include your deployment domain (e.g., your-app.vercel.app).
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated list of trusted origins for CSRF protection.
# Must include the scheme (https://).
# For local development:
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000